	},
	"dependencies": {
		"lint-staged": "^16.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"turbo": "^2.7.5",
		"typescript": "^5.9.3"
	},
	"homepage": "https://github.com/Iceman8911/sugarbox#readme",
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": "bunx biome check --write"
