{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "output/**", "generated/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"test": {
			"dependsOn": ["^test", "lint", "format"]
		}
	},
	"ui": "tui"
}
