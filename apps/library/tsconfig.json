{
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"rootDir": "./src",
		"skipLibCheck": true,
		"strict": true
	},
	"exclude": ["node_modules", "dist", "bunup.config.ts"],
	"extends": "../../tsconfig.json",
	"include": ["src/**/*"],
	"paths": {
		"~/*": ["./src/*"]
	}
}
