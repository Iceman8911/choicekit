---
import {
	bestSource,
	flattenReflections,
	joinText,
	readableKind,
	renderTypeInline,
	type TypeDocProject,
} from "../../../lib/typedoc-data";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

export async function getStaticPaths() {
	const project = (await import("../../../generated/docs.json"))
		.default as TypeDocProject;
	const all = flattenReflections(project);

	const names = all
		.map((r) => (typeof r.name === "string" ? r.name.trim() : ""))
		.filter((n) => n.length > 0 && !n.startsWith("__"));

	const uniqueNames = Array.from(new Set(names)).sort((a, b) =>
		a.localeCompare(b),
	);

	return uniqueNames.map((name) => ({
		params: { name: encodeURIComponent(name) },
	}));
}

type RouteParams = { name: string };

const { name: rawName = "" } = Astro.params as RouteParams;

function safeDecodeURIComponent(value: string): string {
	try {
		return decodeURIComponent(value);
	} catch {
		return value;
	}
}

function normalize(value: string): string {
	return value.trim().toLowerCase();
}

const requestedName = safeDecodeURIComponent(rawName);
const project = (await import("../../../generated/docs.json"))
	.default as TypeDocProject;

const wanted = normalize(requestedName);
const all = flattenReflections(project);

const matchesExact =
	wanted.length > 0
		? all.filter(
				(r) => typeof r.name === "string" && normalize(r.name) === wanted,
			)
		: [];

const matches =
	matchesExact.length > 0
		? matchesExact
		: wanted.length > 0
			? all.filter(
					(r) =>
						typeof r.name === "string" && normalize(r.name).includes(wanted),
				)
			: [];

const pageTitle = requestedName
	? `Reference: ${requestedName}`
	: "Reference: (missing name)";
---

<StarlightPage frontmatter={{title: pageTitle}}>

  <h1 style="margin-bottom: 0.25rem">{pageTitle}</h1>
  <p style="margin-top: 0; opacity: 0.85">
	Generated from <code>apps/docs-astro/src/generated/docs.json</code>
  </p>

  {wanted.length === 0 ? (
	<section style="margin-top: 1rem">
		<p>Missing symbol name.</p>
	</section>
  ) : matches.length === 0 ? (
	<section style="margin-top: 1rem">
		<p>
			No symbols found for <code>{requestedName}</code>.
		</p>
		<p style="opacity: 0.85">
			Tip: confirm the symbol is exported from the package entrypoint, then
			regenerate TypeDoc and rebuild the docs.
		</p>
	</section>
  ) : (
	<section style="margin-top: 1rem">
		{matches.map((r) => {
			const summary = joinText(r.comment?.summary);
			const source = bestSource(r);
			const typePreview = renderTypeInline(r.type);

			const id =
				typeof r.id === "number" && Number.isFinite(r.id) ? String(r.id) : null;

			const name =
				typeof r.name === "string" && r.name.trim().length > 0
					? r.name
					: "(unnamed)";

			return (
				<article
					style={{
						background: "rgba(127,127,127,0.04)",
						border: "1px solid rgba(127,127,127,0.18)",
						borderRadius: "0.75rem",
						marginBottom: "1rem",
						padding: "1rem",
					}}
				>
					<div
						style={{
							alignItems: "baseline",
							display: "flex",
							flexWrap: "wrap",
							gap: "0.75rem",
						}}
					>
						<div style={{ fontSize: "1.1rem" }}>
							<code>{name}</code>
						</div>
						<span style={{ opacity: 0.8 }}>{readableKind(r)}</span>
						{id ? <span style={{ opacity: 0.7 }}>id: {id}</span> : null}
					</div>

					{summary ? <p style={{ margin: "0.6rem 0 0" }}>{summary}</p> : null}

					{typePreview ? (
						<p style={{ margin: "0.6rem 0 0", opacity: 0.9 }}>
							<strong>Type:</strong> <code>{typePreview}</code>
						</p>
					) : null}

					{source?.fileName ? (
						<p style={{ margin: "0.6rem 0 0", opacity: 0.9 }}>
							<strong>Source:</strong>{" "}
							<code>
								{source.fileName}
								{typeof source.line === "number" ? `:${source.line}` : ""}
							</code>{" "}
							{source.url ? (
								<a href={source.url} rel="noreferrer" target="_blank">
									(view)
								</a>
							) : null}
						</p>
					) : null}

					{id ? (
						<p style={{ margin: "0.75rem 0 0" }}>
							<a href={`/reference/id/${id}`}>
								View by id: <code>{id}</code>
							</a>
						</p>
					) : null}
				</article>
			);
		})}
	</section>
  )}
</StarlightPage>
