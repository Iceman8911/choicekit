{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"dependsOn": ["choicekit#build"],
			"outputs": ["dist/**", ".output/**", "generated/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["choicekit#build"],
			"inputs": ["$TURBO_DEFAULT$", "../library/**.ts"],
			"persistent": true
		}
	}
}
